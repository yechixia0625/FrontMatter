# FrontMatter - Local Environment Configuration

# App
FRONTMATTER_APP_NAME="FrontMatter"
FRONTMATTER_DEBUG=true
FRONTMATTER_API_V1_PREFIX="/api/v1"
FRONTMATTER_API_HOST="127.0.0.1"
FRONTMATTER_API_PORT=8000
FRONTMATTER_WEB_HOST="127.0.0.1"
FRONTMATTER_WEB_PORT=3000
API_PROXY_TARGET="http://127.0.0.1:8000"

# Database
FRONTMATTER_DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/frontmatter"
FRONTMATTER_DATABASE_POOL_SIZE=20

# Redis
FRONTMATTER_REDIS_URL="redis://localhost:6379/0"

# LLM
FRONTMATTER_LLM_API_KEY="your-zhipu-api-key-here"
FRONTMATTER_LLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
FRONTMATTER_LLM_MODEL="glm-4.1v-thinking-flash"
FRONTMATTER_LLM_TIMEOUT_SECONDS=120

# Google Places API (server side only; enable Places API (New))
FRONTMATTER_GOOGLE_PLACES_API_KEY="your-google-places-api-key-here"
FRONTMATTER_GOOGLE_PLACES_SEARCH_RADIUS_METERS=500
FRONTMATTER_ONEMAP_ACCESS_TOKEN=""

# Demo auth for public test environments
FRONTMATTER_DEMO_AUTH_ENABLED=true
FRONTMATTER_DEMO_AUTH_USERNAME="demo"
FRONTMATTER_DEMO_AUTH_PASSWORD="change-me"
FRONTMATTER_DEMO_AUTH_SECRET="change-me-to-a-long-random-string"
FRONTMATTER_DEMO_AUTH_COOKIE_NAME="frontmatter_demo_session"

# Agent Concurrency
FRONTMATTER_MAX_CONCURRENT_AGENTS=4
FRONTMATTER_AGENT_LOG_BUFFER_SIZE=50

# SSE
FRONTMATTER_SSE_HEARTBEAT_INTERVAL=15
